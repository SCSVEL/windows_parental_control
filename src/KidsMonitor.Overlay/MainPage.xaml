<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KidsMonitor_Overlay.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KidsMonitor_Overlay"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#FF101010">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Width="420">
            <TextBlock x:Name="HeadingText"
                       Text="Time's up!"
                       FontSize="64"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="SubtitleText"
                       Text="Your screen time limit has been reached. Ask a parent to unlock."
                       FontSize="24"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="800" />

            <PasswordBox x:Name="PasswordBox" PlaceholderText="Parent password" Margin="0,24,0,0" />
            <Button x:Name="UnlockButton" Content="Unlock" Click="UnlockButton_Click" HorizontalAlignment="Center" />
            <TextBlock x:Name="ErrorText" Foreground="#FFFF6B6B" HorizontalAlignment="Center" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Page>
