<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="KidsMonitor_Tray.FirstRunSetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KidsMonitor_Tray"
    Title="KidsMonitor Setup">
    <Grid Padding="24" RowSpacing="12" Width="380">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Set up KidsMonitor" FontSize="20" FontWeight="Bold" />

        <TextBlock Grid.Row="1" Text="Daily time limit (minutes)" />
        <NumberBox x:Name="LimitBox" Grid.Row="2" Value="120" Minimum="1" Maximum="1440" SpinButtonPlacementMode="Inline" />

        <PasswordBox x:Name="PasswordBox" Grid.Row="3" Header="Parent password" PlaceholderText="Enter a password" />
        <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="4" Header="Confirm password" PlaceholderText="Re-enter the password" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="12">
            <Button x:Name="SubmitButton" Content="Finish setup" Click="SubmitButton_Click" />
            <TextBlock x:Name="ErrorText" Foreground="Red" VerticalAlignment="Center" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
