<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="KidsMonitor_Tray.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KidsMonitor_Tray"
    xmlns:tb="using:H.NotifyIcon">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Icon is set in code-behind (App.xaml.cs), not via IconSource here: IconSource
                 resolves through a ms-appx:/// URI, which needs package identity and reliably
                 crashes (0xc000027b) in this unpackaged app.
                 ContextMenuMode intentionally left at its default (PopupMenu, a native Win32
                 menu) rather than "SecondWindow": SecondWindow renders the menu in a real
                 transparent WinUI Window, which hits the same 0xc000027b AppWindow/unpackaged
                 crash documented in the M2 Overlay work (see ProcessLauncher/LockController
                 history): this was the actual cause of Tray crashing on every launch. -->
            <tb:TaskbarIcon x:Key="TrayIcon"
                            ToolTipText="KidsMonitor" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
