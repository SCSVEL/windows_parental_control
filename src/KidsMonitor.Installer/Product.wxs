<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui" xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package Name="KidsMonitor" Manufacturer="KidsMonitor" Version="0.9.0.0" UpgradeCode="e94dba21-ed90-4c13-8d3d-48f7493ac7ee">
    <!-- AllowSameVersionUpgrades: without it, reinstalling an MSI built with the same Version
         (each build gets a fresh auto-generated ProductCode, but Version here is bumped
         manually, not per-build) is NOT recognized as an upgrade: MSI treats it as a second,
         unrelated product with the same UpgradeCode, leaving a duplicate entry in "Installed
         apps" instead of replacing the old one. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of KidsMonitor is already installed." AllowSameVersionUpgrades="yes" />
    <MediaTemplate EmbedCab="yes" />

    <!-- Runs on install, upgrade, and uninstall alike: Tray.exe is a per-user Run-key/
         service-launched process, and Overlay.exe intentionally resists ordinary close
         attempts while a lock is showing, so both need TerminateProcess rather than relying
         on the app to exit itself. Without this, an uninstall while Tray/Overlay are running
         leaves their files locked (Windows Installer schedules a pending-delete-on-reboot,
         so files linger) and/or orphaned processes after removal.
         util:CloseApplication alone doesn't prevent Windows Installer's own built-in Restart
         Manager "Files In Use" prompt: its custom action is scheduled after InstallValidate
         (the point where that RM scan happens), so the dialog still appears first and this
         only cleans up afterward. Killing both processes via taskkill scheduled explicitly
         Before="InstallValidate" (below) is what actually prevents the prompt; these
         CloseApplication entries are kept as a harmless secondary safety net (no-op once
         taskkill has already ended the processes). -->
    <util:CloseApplication
        Id="CloseTrayExe"
        Target="KidsMonitor.Tray.exe"
        Description="KidsMonitor Tray must close to continue."
        CloseMessage="yes"
        Timeout="3"
        TerminateProcess="1"
        RebootPrompt="no" />
    <util:CloseApplication
        Id="CloseOverlayExe"
        Target="KidsMonitor.Overlay.exe"
        Description="KidsMonitor Overlay must close to continue."
        CloseMessage="yes"
        Timeout="3"
        TerminateProcess="1"
        RebootPrompt="no" />

    <!-- Kills Tray.exe and Overlay.exe (single taskkill call, one /IM per image) before
         InstallValidate runs its Restart Manager file-in-use scan: must be Execute="immediate"
         since deferred custom actions can't be scheduled that early in the sequence. Runs
         unconditionally (install, upgrade, and uninstall), which is exactly what's needed since
         Tray/Overlay are plain user-session processes the Service doesn't manage the lifecycle
         of; stopping KidsMonitorService (ServiceControl below) does not touch them. -->
    <SetProperty
        Id="WixQuietExecCmdLine"
        Value="&quot;[System64Folder]taskkill.exe&quot; /F /IM KidsMonitor.Tray.exe /IM KidsMonitor.Overlay.exe"
        Before="KillTrayAndOverlay"
        Sequence="execute" />
    <CustomAction
        Id="KillTrayAndOverlay"
        BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
        DllEntry="WixQuietExec"
        Execute="immediate"
        Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="KillTrayAndOverlay" Before="InstallValidate" />
    </InstallExecuteSequence>

    <Icon Id="AppIcon.ico" SourceFile="..\KidsMonitor.Tray\Assets\AppIcon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <!-- Gives the install a Welcome/License/Progress/Exit dialog sequence (there was none
         before: a silent-looking install with no confirmation once it finished) via the
         stock minimal dialog set. -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!--
      Service, Tray, and Overlay each get their own sibling folder rather than one flat
      directory, since all three are independently self-contained (.NET + WinAppSDK)
      publishes, so harvesting them into a single directory would collide on shared
      framework DLL names. KidsMonitor.Service's ResolveOverlayExecutablePath expects
      exactly this ..\Overlay\ layout.
    -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="KidsMonitor">
        <Directory Id="ServiceFolder" Name="Service" />
        <Directory Id="TrayFolder" Name="Tray" />
        <Directory Id="OverlayFolder" Name="Overlay" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="KidsMonitor" />
    </StandardDirectory>

    <ComponentGroup Id="ServiceDependencyFiles" Directory="ServiceFolder" Source="$(var.ServicePublishDir)">
      <Files Include="**">
        <Exclude Files="KidsMonitor.Service.exe" />
      </Files>
    </ComponentGroup>

    <ComponentGroup Id="TrayDependencyFiles" Directory="TrayFolder" Source="$(var.TrayPublishDir)">
      <Files Include="**">
        <Exclude Files="KidsMonitor.Tray.exe" />
      </Files>
    </ComponentGroup>

    <ComponentGroup Id="OverlayFiles" Directory="OverlayFolder" Source="$(var.OverlayPublishDir)">
      <Files Include="**" />
    </ComponentGroup>

    <!-- Split out from the harvested files above so ServiceInstall/ServiceControl can attach to it. -->
    <Component Id="ServiceExeComponent" Directory="ServiceFolder">
      <File Id="ServiceExe" Source="$(var.ServicePublishDir)KidsMonitor.Service.exe" KeyPath="yes" />
      <ServiceInstall
          Id="ServiceInstaller"
          Name="KidsMonitorService"
          DisplayName="KidsMonitor Service"
          Description="Enforces KidsMonitor screen-time limits. Do not stop -- this is what keeps the lock tamper-resistant."
          Start="auto"
          Type="ownProcess"
          Account="LocalSystem"
          ErrorControl="normal" />
      <ServiceControl
          Id="ServiceController"
          Name="KidsMonitorService"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      <!-- Without this, an unhandled exception in any BackgroundService (the Generic Host's
           default BackgroundServiceExceptionBehavior is StopHost, so one bad tick anywhere
           stops the whole process) leaves the Service dead until the next reboot, with no one
           left to run the daily reset or lift a lock overnight. SC_ACTION_RESTART on all three
           failures, reset after a day of continuous uptime so a crash loop doesn't retry
           forever. -->
      <util:ServiceConfig
          ServiceName="KidsMonitorService"
          FirstFailureActionType="restart"
          SecondFailureActionType="restart"
          ThirdFailureActionType="restart"
          RestartServiceDelayInSeconds="5"
          ResetPeriodInDays="1" />
    </Component>

    <!-- Split out so the HKLM Run autostart key can attach to it. This only covers subsequent
         logons/reboots: the Service (KidsMonitor.Service/TrayLauncherService.cs) launches Tray
         immediately in the active session right after install, reusing the CreateProcessAsUser
         path already proven for the Overlay (see ProcessLauncher). -->
    <Component Id="TrayExeComponent" Directory="TrayFolder">
      <File Id="TrayExe" Source="$(var.TrayPublishDir)KidsMonitor.Tray.exe" KeyPath="yes" />
      <RegistryValue
          Root="HKLM"
          Key="Software\Microsoft\Windows\CurrentVersion\Run"
          Name="KidsMonitorTray"
          Type="string"
          Value="[TrayFolder]KidsMonitor.Tray.exe" />
    </Component>

    <Component Id="ApplicationShortcut" Directory="ApplicationProgramsFolder">
      <Shortcut
          Id="TrayShortcut"
          Name="KidsMonitor"
          Description="KidsMonitor parental control"
          Target="[TrayFolder]KidsMonitor.Tray.exe"
          WorkingDirectory="TrayFolder"
          Icon="AppIcon.ico" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\KidsMonitor" Name="ShortcutInstalled" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Feature Id="Main" Title="KidsMonitor" Level="1">
      <ComponentGroupRef Id="ServiceDependencyFiles" />
      <ComponentGroupRef Id="TrayDependencyFiles" />
      <ComponentGroupRef Id="OverlayFiles" />
      <ComponentRef Id="ServiceExeComponent" />
      <ComponentRef Id="TrayExeComponent" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>
  </Package>
</Wix>
